<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Calculator.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="500"
        Width="350" Height="500"
        WindowStartupLocation="CenterScreen"
        x:Class="Calculator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Calculator">

    <Grid RowDefinitions="Auto, *">
        
        <!-- Bound to the DisplayText property in our ViewModel -->
        <TextBox Grid.Row="0" 
                 Text="{Binding DisplayText}" 
                 FontSize="36" 
                 TextAlignment="Right" 
                 VerticalContentAlignment="Center"
                 IsReadOnly="True" 
                 Margin="10" 
                 Height="80"/>

        <Grid Grid.Row="1" RowDefinitions="*, *, *, *" ColumnDefinitions="*, *, *, *" Margin="10">
            <Grid.Styles>
                <Style Selector="Button">
                    <Setter Property="FontSize" Value="20"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="4"/>
                </Style>

                <!-- Hover style for the Equals and Clear buttons -->
                <Style Selector="Button.clear-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="#A7291A" /> <!-- Darker Red -->
                </Style>

                <!-- Hover style for the GREEN button -->
                <Style Selector="Button.equal-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="#168F49" /> <!-- Darker Green -->
                </Style>
            </Grid.Styles>

            <!-- Row 1 -->
            <Button Grid.Row="0" Grid.Column="0" Content="(" Command="{Binding OperatorCommand}" CommandParameter="("/>
            <Button Grid.Row="0" Grid.Column="1" Content=")" Command="{Binding OperatorCommand}" CommandParameter=")"/>
            <Button Grid.Row="0" Grid.Column="2" 
                    Command="{Binding OperatorCommand}" 
                    CommandParameter="*">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="x" VerticalAlignment="Bottom"/>
                        <TextBlock Text="n" FontSize="10" Margin="-2,0,0,6" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button Grid.Row="0" Grid.Column="3" Content="&#x221A;"  Command="{Binding OperatorCommand}" CommandParameter="-"/>
            <Button Grid.Row="0" Grid.Column="4" Content="!" Command="{Binding OperatorCommand}" CommandParameter="-"/>


            <!-- Row 2 -->
            <Button Grid.Row="1" Grid.Column="0" Content="sin" Command="{Binding TrigonometricCommand}" CommandParameter="7"/>
            <Button Grid.Row="1" Grid.Column="1" Content="cos" Command="{Binding TrigonometricCommand}" CommandParameter="8"/>
            <Button Grid.Row="1" Grid.Column="2" Content="tan" Command="{Binding TrigonometricCommand}" CommandParameter="9"/>
            <Button Grid.Row="1" Grid.Column="3" Content="ln" Command="{Binding LogarithmicCommand}" CommandParameter="+"/>
            <Button Grid.Row="1" Grid.Column="4" Content="log" Command="{Binding LogarithmicCommand}" CommandParameter="+"/>


            <!-- Row 3 -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" Command="{Binding NumberCommand}" CommandParameter="4"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" Command="{Binding NumberCommand}" CommandParameter="5"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" Command="{Binding NumberCommand}" CommandParameter="6"/>
            <Button Grid.Row="2" Grid.Column="3" Content="+" Command="{Binding OperatorCommand}" CommandParameter="+"/>
            <Button Grid.Row="2" Grid.Column="4" Content="+" Command="{Binding OperatorCommand}" CommandParameter="+"/>
            
            <!-- Row 4 -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" Command="{Binding NumberCommand}" CommandParameter="1"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" Command="{Binding NumberCommand}" CommandParameter="2"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" Command="{Binding NumberCommand}" CommandParameter="3"/>
            <Button Grid.Row="3" Grid.Column="3" Content="=" Command="{Binding EqualCommand}"/>
            <Button Grid.Row="3" Grid.Column="4" Content="=" Command="{Binding EqualCommand}"/>
        
            <!-- Row 5 -->
            <Button Grid.Row="4" Grid.Column="0" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
            <Button Grid.Row="4" Grid.Column="1" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
            <Button Grid.Row="4" Grid.Column="2" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
            <Button Grid.Row="4" Grid.Column="3" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
            <Button Grid.Row="4" Grid.Column="4" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
       
            <!-- Row 6 -->
            <Button Grid.Row="5" Grid.Column="0" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
            <Button Grid.Row="5" Grid.Column="1" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
            <Button Grid.Row="5" Grid.Column="2" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
            <Button Grid.Row="5" Grid.Column="3" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
            <Button Grid.Row="5" Grid.Column="4" Content="0" Command="{Binding NumberCommand}" CommandParameter="0" Grid.ColumnSpan="2"/>
       
        </Grid>
    </Grid>
</Window>
